APP_NAME=Document Classifier Service
APP_VERSION=0.1.0
DEBUG=true

DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/documents
DATABASE_SYNC_URL=postgresql+psycopg2://app:app@postgres:5432/documents
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=documents
DATABASE_PASSWORD=app

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
QUEUE_NAME=default

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=documents

SFTP_HOST=sftp
SFTP_PORT=22
SFTP_USERNAME=test
SFTP_PASSWORD=test
SFTP_REMOTE_FOLDER=/upload
SFTP_PROCESSED_FOLDER=/processed
SFTP_POLL_INTERVAL_SECONDS=5

VAULT_URL=http://vault:8200
VAULT_TOKEN=root
REQUIRE_VAULT=true
VAULT_SECRET_BASE_PATH=secret/data/doc-classifier

JWT_SECRET_KEY=dev-jwt-secret-key-for-local-demo-minimum-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

SEED_DEMO_USERS=true
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=Admin123!
DEMO_REVIEWER_EMAIL=reviewer@example.com
DEMO_REVIEWER_PASSWORD=Reviewer123!
DEMO_AUDITOR_EMAIL=auditor@example.com
DEMO_AUDITOR_PASSWORD=Auditor123!
